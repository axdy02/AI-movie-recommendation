APP_NAME="AI Movie Recommendation API"
API_VERSION="0.1.0"
API_PREFIX="/api/v1"
ENVIRONMENT="local"
DEBUG="true"

DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/ai_movie_recommendation"

SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
BACKEND_CORS_ORIGIN_REGEX="http://(localhost|127\.0\.0\.1):[0-9]+"

OLLAMA_MODEL="llama3.1"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_TIMEOUT_SECONDS="1.5"

VITE_API_BASE_URL="http://localhost:8000"
VITE_USE_MOCKS="false"
